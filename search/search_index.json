{"config":{"lang":["en"],"separator":"[\\s\\-]+","pipeline":["stopWordFilter"]},"docs":[{"location":"","title":"About","text":"<p>\uc548\ub155\ud558\uc138\uc694. \uc0ac\ub78c\ub4e4\uc5d0\uac8c \ud544\uc694\ud55c \uc9c0\uc2dd\uc744 \ub098\ub204\uace0 \uacf5\uc720\ud558\uace0 \uc2f6\uc740 \uac1c\ubc1c\uc790 \ud5c8\uac74\uc601\uc785\ub2c8\ub2e4. \uc804\ubb38\uc5f0\uad6c\uc694\uc6d0 3\ub144, \uc0bc\uc131 \uccad\ub144 \uc18c\ud504\ud2b8\uc6e8\uc5b4 \uc544\uce74\ub370\ubbf8 (SSAFY) 1\ud559\uae30 \uacfc\uc815\uc744 \uac70\uccd0 \ud604\uc7ac\ub294 Back-end \uac1c\ubc1c\uc790\ub85c \uc77c\ud558\uace0 \uc788\uc2b5\ub2c8\ub2e4. \uc8fc\ub85c \uc0ac\uc6a9\ud558\ub294 \uc5b8\uc5b4\ub294 Java, Python\uc774\uace0 \uc0c8\ub85c\uc6b4 \uac83\uc744 \ubc30\uc6b0\uace0 \uc2dc\ub3c4\ud558\ub294 \uac83\uc744 \uc88b\uc544\ud569\ub2c8\ub2e4.</p>"},{"location":"blog/","title":"Blog","text":""},{"location":"projects/","title":"Projects","text":""}]}